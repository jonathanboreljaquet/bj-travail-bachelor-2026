{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": ".",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*", "prisma/seeds/**/*"],
    "exclude": ["dist", "node_modules", "**/*.test.ts", "*.cjs"]
}
