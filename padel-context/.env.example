# =============================================================================
# Padel Context - Variables d'environnement
# =============================================================================
# -----------------------------------------------------------------------------
# db - Base de données PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_NAME=padel-context-db
DATABASE_USER=padel-context-db_user
DATABASE_PASSWORD=padel-context-db_password
DATABASE_HOST_PORT=5433
# -----------------------------------------------------------------------------
# api - API REST Node.js / Express / Prisma
# -----------------------------------------------------------------------------
API_HTTP_PORT=3000
AUTH_JWT_SECRET=
MAX_UPCOMING_MATCHES=5
# -----------------------------------------------------------------------------
# mcp-server - Serveur MCP
# -----------------------------------------------------------------------------
MCP_SERVER_HTTP_PORT=3001
MCP_INTERNAL_SECRET=
# -----------------------------------------------------------------------------
# mcp-client-web - Client MCP web Next.js
# -----------------------------------------------------------------------------
MCP_CLIENT_WEB_HTTP_PORT=3002
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=
