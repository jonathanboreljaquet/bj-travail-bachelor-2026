// -----------------------------------------------------------------------------
// CONFIGURATION PRISMA
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

/// Type d'infrastructure du terrain.
enum CourtType {
  INDOOR
  OUTDOOR
  COVERED
}

/// Statut du match.
enum MatchStatus {
  OPEN
  COMPLETED
  CANCELED
}

// -----------------------------------------------------------------------------
// MODÈLES DE DONNÉES
// -----------------------------------------------------------------------------

/// Représente un joueur inscrit sur la plateforme.
model User {
  id        Int      @id @default(autoincrement())
  firstname String
  lastname  String
  email     String   @unique
  /// Mot de passe haché.
  password  String
  /// Évaluation du niveau de jeu (ex: de 1 pour débutant à 10 pour expert).
  level     Int      @default(1)
  createdAt DateTime @default(now()) @db.Timestamptz()

  /// Plafond mensuel de tokens autorisés pour les fonctionnalités LLM.
  monthlyTokenLimit Int @default(500000)
  /// Tokens consommés sur le mois en cours.
  currentMonthTokens Int @default(0)

  createdMatches Match[]       @relation("MatchCreator")
  participations Participant[]
  llmUsageLogs LlmUsageLog[]
}

/// Représente un club sportif contenant un ou plusieurs terrains.
model Club {
  id          Int    @id @default(autoincrement())
  name        String
  city        String
  postalCode  String
  openingTime String
  closingTime String

  courts Court[]
}

/// Représente un terrain de jeu spécifique au sein d'un club.
model Court {
  id              Int       @id @default(autoincrement())
  name            String
  type            CourtType @default(OUTDOOR)
  /// Indique si le terrain dispose d'un coffre de matériel (raquettes/balles) accessible aux joueurs.
  hasEquipmentBox Boolean
  /// Prix facturé par joueur pour la durée d'un créneau.
  pricePerPerson  Float
  /// Durée standard d'un créneau de réservation en minutes.
  slotDuration    Int

  club_id Int
  club    Club    @relation(fields: [club_id], references: [id])
  matches Match[]
}

/// Représente une session de jeu créée par un utilisateur sur un terrain donné.
model Match {
  id              Int         @id @default(autoincrement())
  startTime       DateTime    @db.Timestamptz(3)
  endTime         DateTime    @db.Timestamptz(3)
  status          MatchStatus @default(OPEN)
  /// Nombre de places restantes avant que le match ne soit complet.
  availableSpots  Int

  court_id     Int
  court        Court         @relation(fields: [court_id], references: [id])
  creator_id   Int
  creator      User          @relation("MatchCreator", fields: [creator_id], references: [id])
  participants Participant[]
}

/// Table de liaison (Many-to-Many) représentant les participants à un match.
model Participant {
  user_id  Int
  match_id Int
  joinedAt DateTime @default(now()) @db.Timestamptz()

  user  User  @relation(fields: [user_id], references: [id])
  match Match @relation(fields: [match_id], references: [id])

  @@id([user_id, match_id])
}

/// Historique de consommation de l'API LLM pour la traçabilité et le calcul des quotas.
model LlmUsageLog {
  id           Int      @id @default(autoincrement())
  user_id      Int
  createdAt    DateTime @default(now()) @db.Timestamptz()
  prompt       String
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  model        String

  user User @relation(fields: [user_id], references: [id])
}
