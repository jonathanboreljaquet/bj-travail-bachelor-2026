	file = {Full Text PDF:C\:\\Users\\jonat\\Zotero\\storage\\PJTLHZBQ\\Silva et al. - 2025 - Beyond Formal Semantics for Capabilities and Skills Model Context Protocol in Manufacturing.pdf:application/pdf;Snapshot:C\:\\Users\\jonat\\Zotero\\storage\\72KPRP59\\2506.html:text/html},
